# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application Configuration
NEXT_PUBLIC_APP_URL=https://your-staff-app.example
GOOGLE_ALLOWED_DOMAIN=your-school.example
BOOTSTRAP_SUPER_ADMIN_EMAILS=admin@your-school.example

# Supabase Google OAuth Provider Configuration
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Web Push Notification Keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@your-school.example

# Google Calendar Sync Configuration (Service Account Auth)
GOOGLE_CALENDAR_SYNC_ENABLED=false
GOOGLE_CALENDAR_ID=your-google-calendar-id
GOOGLE_CALENDAR_SERVICE_ACCOUNT_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CALENDAR_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
